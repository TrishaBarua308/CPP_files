#include <bits/stdc++.h>
using namespace std;

int main() 
{
	// your code goes here
	int t;    cin>>t;
	
	while(t--)
	{
	    int n;  cin>>n;
	    int ans = 0;
	    
	    while(n!=0)
	    {
	        int rem = n%10;
	        ans = ans*10 + rem; 
	        n /= 10;
	    }
	    
	    cout<<ans<<endl;
	    
	}
	
	return 0;

}
