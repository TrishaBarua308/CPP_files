#include<bits/stdc++.h>
#define optimize ios::sync_with_stdio(0); cin.tie(0); cout.tie(0);
#define ll long long
#define endl "\n"
using namespace std;
int main()
{
    optimize;

    int n;  cin>>n;
    int a[n+1];
    for(int i=1; i<=n; i++)  cin>>a[i];

    int ff[n+1]; // for tracking
    for(int i=1; i<=n; i++)  ff[i]=0;

    for(int i=1; i<=n; i++)
    {
        if(ff[i]==0)
        {
            ff[a[i]]=1;
        }
    }

    int c = count(ff+1, ff+n+1, 0);

    cout<<c<<endl;
    for(int i=1; i<=n; i++)
    {
        if(ff[i]==0) cout<<i<<" ";
    }
    cout<<endl;


    return 0;

}
